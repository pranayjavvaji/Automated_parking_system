    def browse_input(self):
        filepath = filedialog.askopenfilename(
            title="Select video file",
            filetypes=[
                ("Video files", "*.mp4 *.avi *.mkv *.mov *.flv *.wmv"),
                ("All files", "*.*")
            ]
        )
        if filepath:
            self.input_path.set(filepath)
    
    def browse_output(self):
        folder = filedialog.askdirectory(title="Select output folder")
        if folder:
            self.output_path.set(folder)
    
    def log(self, message):
        self.log_text.insert(tk.END, message + "\n")
        self.log_text.see(tk.END)
        self.root.update()
    
    def convert_single(self):
        input_file = self.input_path.get()
        if not input_file or not os.path.exists(input_file):
            messagebox.showerror("Error", "Please select a valid input video file.")
            return
        
        output_folder = self.output_path.get()
        os.makedirs(output_folder, exist_ok=True)
        
        base_name = os.path.splitext(os.path.basename(input_file))[0]
        output_file = os.path.join(output_folder, f"{base_name}_mobile.mp4")
        
        self.progress.start()
        self.status_var.set("Converting...")
        
        def convert_thread():
            success = self.converter.convert_to_mobile(
                input_file, output_file, self.quality.get()
            )
            
            self.progress.stop()
            if success:
                self.status_var.set("Conversion successful!")
                self.log(f"✅ Converted: {os.path.basename(input_file)}")
                messagebox.showinfo("Success", "Video converted successfully!")
            else:
                self.status_var.set("Conversion failed")
                self.log(f"❌ Failed: {os.path.basename(input_file)}")
                messagebox.showerror("Error", "Conversion failed!")
        
        threading.Thread(target=convert_thread, daemon=True).start()
    
    def convert_folder(self):
        input_folder = self.input_path.get()
        if not input_folder or not os.path.exists(input_folder):
            messagebox.showerror("Error", "Please select a valid input folder.")
            return
        
        self.progress.start()
        self.status_var.set("Converting folder...")
        
        def batch_thread():
            self.converter.batch_convert(
                input_folder, self.output_path.get(), self.quality.get()
            )
            
            self.progress.stop()
            self.status_var.set("Batch conversion complete!")
            self.log("✅ Batch conversion complete!")
            messagebox.showinfo("Complete", "Batch conversion finished!")
        
        threading.Thread(target=batch_thread, daemon=True).start()
    
    def extract_frames(self):
        input_file = self.input_path.get()
        if not input_file or not os.path.exists(input_file):
            messagebox.showerror("Error", "Please select a valid input video file.")
            return
        
        output_folder = os.path.join(self.output_path.get(), "frames")
        
        self.progress.start()
        self.status_var.set("Extracting frames...")
        
        def extract_thread():
            self.converter.extract_frames(input_file, output_folder, fps=1)
            
            self.progress.stop()
            self.status_var.set("Frame extraction complete!")
            self.log(f"✅ Frames extracted to: {output_folder}")
            messagebox.showinfo("Complete", "Frames extracted successfully!")
        
        threading.Thread(target=extract_thread, daemon=True).start()

# Command-line interface
def command_line_interface():
    import argparse
    
    parser = argparse.ArgumentParser(description="Convert surveillance videos to mobile format")
    parser.add_argument("input", help="Input video file or folder")
    parser.add_argument("-o", "--output", help="Output file or folder")
    parser.add_argument("-q", "--quality", choices=["good", "better", "best"], 
                       default="better", help="Output quality")
    parser.add_argument("-b", "--batch", action="store_true", 
                       help="Batch convert all videos in folder")
    parser.add_argument("-e", "--extract", action="store_true",
                       help="Extract frames instead of converting")
    parser.add_argument("-fps", type=float, default=1.0,
                       help="Frames per second to extract (default: 1)")
    parser.add_argument("--gui", action="store_true", help="Launch GUI version")
    
    args = parser.parse_args()
    
    if args.gui:
        VideoConverterGUI()
        return
    
    converter = SurveillanceVideoConverter()
    
    if not converter.ffmpeg_path:
        print("❌ FFmpeg not found! Please install FFmpeg first.")
        print("   Download from: https://ffmpeg.org/download.html")
        return
    
    if args.extract:
        output_folder = args.output or os.path.join(os.getcwd(), "extracted_frames")
        converter.extract_frames(args.input, output_folder, args.fps)
    
    elif args.batch:
        converter.batch_convert(args.input, args.output, args.quality)
    
    else:
        converter.convert_to_mobile(args.input, args.output, args.quality)

