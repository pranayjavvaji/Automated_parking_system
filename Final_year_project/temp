class SurveillanceVideoConverter:
    def __init__(self, ffmpeg_path=None):
        # Try to find FFmpeg automatically
        self.ffmpeg_path = ffmpeg_path or self.find_ffmpeg()
        
        if not self.ffmpeg_path:
            print("❌ FFmpeg not found!")
            self.ask_for_ffmpeg_path()
    
    def find_ffmpeg(self):
        """Try to find FFmpeg automatically"""
        possible_paths = [
            r"C:\ffmpeg\bin\ffmpeg.exe",
            r"C:\Program Files\ffmpeg\bin\ffmpeg.exe",
            r"C:\Users\javva\Downloads\Final_year_project\ffmpeg\bin\ffmpeg.exe",
            r"C:\ffmpeg\ffmpeg\bin\ffmpeg.exe",
            "/usr/local/bin/ffmpeg",  # Mac/Linux
            "/usr/bin/ffmpeg",        # Linux
            "ffmpeg"                  # If in PATH
        ]
        
        for path in possible_paths:
            if os.path.exists(path):
                print(f"✅ Found FFmpeg at: {path}")
                return path
        
        return None
    
    def ask_for_ffmpeg_path(self):
        """Ask user to provide FFmpeg path"""
        root = tk.Tk()
        root.withdraw()
        
        filepath = filedialog.askopenfilename(
            title="Select FFmpeg executable",
            filetypes=[("Executable files", "*.exe"), ("All files", "*.*")]
        )
        
        if filepath and os.path.exists(filepath):
            self.ffmpeg_path = filepath
            print(f"✅ Using FFmpeg at: {filepath}")
        else:
            print("❌ FFmpeg is required for video conversion")
            exit(1)
    
    def check_ffmpeg(self):
        """Verify FFmpeg works"""
        try:
            result = subprocess.run(
                [self.ffmpeg_path, '-version'],
                capture_output=True,
                text=True,
                timeout=5
            )
            return result.returncode == 0
        except:
            return False
    
    def get_video_info(self, input_file):
        """Get detailed information about video file"""
        if not os.path.exists(input_file):
            return None
        
        cmd = [
            self.ffmpeg_path,
            '-i', input_file,
            '-hide_banner'
        ]
        
        try:
            process = subprocess.Popen(
                cmd,
                stderr=subprocess.PIPE,
                stdout=subprocess.PIPE,
                creationflags=subprocess.CREATE_NO_WINDOW if os.name == 'nt' else 0
            )
            
            _, stderr = process.communicate(timeout=10)
            output = stderr.decode('utf-8', errors='ignore')
            
            info = {
                'filename': os.path.basename(input_file),
                'path': input_file,
                'size_mb': round(os.path.getsize(input_file) / (1024 * 1024), 2),
                'modified': datetime.fromtimestamp(os.path.getmtime(input_file)).strftime("%Y-%m-%d %H:%M:%S")
            }
            
            # Parse video stream info
            if 'Video:' in output:
                video_line = [line for line in output.split('\n') if 'Video:' in line][0]
                
                # Resolution
                resolution_match = re.search(r'(\d{3,4})x(\d{3,4})', video_line)
                if resolution_match:
                    info['resolution'] = f"{resolution_match.group(1)}x{resolution_match.group(2)}"
                
                # Codec
                if 'h264' in video_line.lower():
                    info['codec'] = 'H.264'
                elif 'h265' in video_line.lower() or 'hevc' in video_line.lower():
                    info['codec'] = 'H.265'
                elif 'mpeg4' in video_line.lower():
                    info['codec'] = 'MPEG-4'
                else:
                    info['codec'] = 'Unknown'
                
                # FPS
                fps_match = re.search(r'(\d+\.?\d*)\s+fps', video_line)
                if fps_match:
                    info['fps'] = float(fps_match.group(1))
            
            # Parse duration
            duration_match = re.search(r'Duration:\s*(\d{2}):(\d{2}):(\d{2}\.?\d*)', output)
            if duration_match:
                hours, minutes, seconds = duration_match.groups()
                info['duration'] = f"{hours}:{minutes}:{seconds.split('.')[0]}"
            
            # Check if already mobile compatible
            info['mobile_compatible'] = self.is_mobile_compatible(output)
            
            return info
            
        except Exception as e:
            print(f"❌ Error getting video info: {e}")
            return None
    
    def is_mobile_compatible(self, ffmpeg_output):
        """Check if video is already mobile compatible"""
        checks = [
            'h264',                     # H.264 codec
            'yuv420p',                  # Pixel format
            'mp4',                      # Container
            'aac' in ffmpeg_output.lower() or 'mp3'  # Audio codec
        ]
        
        return all(checks)
    
    def convert_to_mobile(self, input_file, output_file=None, quality='good'):
        """
        Convert video to mobile-compatible format
        
        Args:
            input_file: Path to input video
            output_file: Output path (optional)
            quality: 'good', 'better', or 'best'
        """
        if not os.path.exists(input_file):
            print(f"❌ File not found: {input_file}")
            return False
        
        # Get video info first
        print(f"\n📊 Analyzing: {os.path.basename(input_file)}")
        video_info = self.get_video_info(input_file)
        
        if not video_info:
            print("❌ Could not analyze video file")
            return False
        
        print(f"   📐 Resolution: {video_info.get('resolution', 'Unknown')}")
        print(f"   🎞️  Codec: {video_info.get('codec', 'Unknown')}")
        print(f"   ⏱️  Duration: {video_info.get('duration', 'Unknown')}")
        print(f"   💿 Size: {video_info['size_mb']} MB")
        
        # Check if already mobile compatible
        if video_info.get('mobile_compatible', False):
            print("✅ Video is already mobile compatible!")
            choice = input("Convert anyway? (y/n): ").lower()
            if choice != 'y':
                print("Skipping conversion.")
                return True
        
        # Set output filename
        if output_file is None:
            base_name = os.path.splitext(input_file)[0]
            output_file = f"{base_name}_mobile.mp4"
        
        # Quality settings
        quality_presets = {
            'good': {
                'crf': 28,      # Higher = smaller file, lower quality
                'preset': 'fast',
                'audio_bitrate': '96k'
            },
            'better': {
                'crf': 23,
                'preset': 'medium',
                'audio_bitrate': '128k'
            },
            'best': {
                'crf': 18,
                'preset': 'slow',
                'audio_bitrate': '192k'
            }
        }
        
        preset = quality_presets.get(quality, quality_presets['better'])
        
        print(f"\n🔄 Converting to mobile format...")
        print(f"   📱 Quality: {quality}")
        print(f"   💾 Output: {os.path.basename(output_file)}")
        
        # Build FFmpeg command
        cmd = [
            self.ffmpeg_path,
            '-i', input_file,                    # Input file
            '-c:v', 'libx264',                   # H.264 video codec
            '-preset', preset['preset'],         # Encoding speed/quality
            '-crf', str(preset['crf']),          # Constant Rate Factor
            '-pix_fmt', 'yuv420p',               # Required for iOS/Android
            '-profile:v', 'baseline',            # Widest compatibility
            '-level', '3.1',                     # Common mobile level
            '-movflags', '+faststart',           # Optimize for streaming
            '-c:a', 'aac',                       # AAC audio codec
            '-b:a', preset['audio_bitrate'],     # Audio bitrate
            '-f', 'mp4',                         # MP4 container
            '-y',                                # Overwrite output
            output_file                          # Output file
        ]
        
        # Alternative: Copy if already H.264
        if video_info.get('codec', '').lower() == 'h.264':
            print("   ⚡ Using stream copy (already H.264)")
            cmd = [
                self.ffmpeg_path,
                '-i', input_file,
                '-c:v', 'copy',                  # Copy video stream
                '-c:a', 'aac',                   # Convert audio to AAC
                '-b:a', preset['audio_bitrate'],
                '-movflags', '+faststart',
                '-f', 'mp4',
                '-y',
                output_file
            ]
        
        try:
            print("\n⏳ Converting... This may take a while...")
            print("   Press Ctrl+C to cancel")
            print("-" * 50)
            
            # Run conversion with progress
            process = subprocess.Popen(
                cmd,
                stderr=subprocess.PIPE,
                stdout=subprocess.PIPE,
                universal_newlines=True,
                bufsize=1,
                creationflags=subprocess.CREATE_NO_WINDOW if os.name == 'nt' else 0
            )
            
            # Monitor progress
            start_time = datetime.now()
            for line in process.stderr:
                if 'time=' in line:
                    time_match = re.search(r'time=(\d{2}:\d{2}:\d{2}\.\d{2})', line)
                    if time_match:
                        current_time = time_match.group(1)
                        elapsed = datetime.now() - start_time
                        print(f"   Progress: {current_time} | Elapsed: {elapsed.seconds}s", end='\r')
            
            # Wait for completion
            process.wait()
            
            if process.returncode == 0:
                # Get output file info
                if os.path.exists(output_file):
                    output_size = os.path.getsize(output_file) / (1024 * 1024)
                    compression = ((video_info['size_mb'] - output_size) / video_info['size_mb']) * 100
                    
                    print(f"\n✅ Conversion successful!")
                    print(f"   📁 Output: {output_file}")
                    print(f"   💿 New size: {output_size:.2f} MB")
                    print(f"   📉 Compression: {compression:.1f}%")
                    print(f"   📱 Ready for mobile playback!")
                    
                    # Verify the file
                    if self.verify_conversion(output_file):
                        print("   ✓ File verified as mobile compatible")
                    else:
                        print("   ⚠️ File may have issues")
                    
                    return True
                else:
                    print("❌ Output file was not created")
                    return False
            else:
                print(f"\n❌ Conversion failed with code: {process.returncode}")
                return False
                
        except KeyboardInterrupt:
            print("\n\n🛑 Conversion cancelled by user")
            # Try to clean up partial file
            if os.path.exists(output_file):
                os.remove(output_file)
            return False
        except Exception as e:
            print(f"\n❌ Error during conversion: {e}")
            return False
    
    def verify_conversion(self, video_file):
        """Verify the converted video is mobile compatible"""
        cmd = [
            self.ffmpeg_path,
            '-i', video_file,
            '-hide_banner'
        ]
        
        try:
            process = subprocess.Popen(
                cmd,
                stderr=subprocess.PIPE,
                stdout=subprocess.PIPE,
                creationflags=subprocess.CREATE_NO_WINDOW if os.name == 'nt' else 0
            )
            
            _, stderr = process.communicate(timeout=5)
            output = stderr.decode('utf-8', errors='ignore')
            
            checks = [
                'Video: h264' in output,
                'yuv420p' in output,
                'Audio: aac' in output,
                'mp4' in output
            ]
            
            return all(checks)
        except:
            return False
    
    def batch_convert(self, input_folder, output_folder=None, quality='good', file_pattern="*.mp4;*.avi;*.mkv;*.mov"):
        """Convert all videos in a folder"""
        if not os.path.exists(input_folder):
            print(f"❌ Folder not found: {input_folder}")
            return
        
        # Create output folder
        if output_folder is None:
            output_folder = os.path.join(input_folder, "mobile_converted")
        
        os.makedirs(output_folder, exist_ok=True)
        
        # Get list of video files
        patterns = file_pattern.split(';')
        video_files = []
        
        for pattern in patterns:
            video_files.extend(glob.glob(os.path.join(input_folder, pattern)))
        
        if not video_files:
            print(f"❌ No video files found in: {input_folder}")
            return
        
        print(f"\n📁 Found {len(video_files)} video files in: {input_folder}")
        print(f"📁 Output folder: {output_folder}")
        print(f"📱 Quality: {quality}")
        print("-" * 60)
        
        success_count = 0
        failed_count = 0
        
        for i, video_file in enumerate(video_files, 1):
            print(f"\n[{i}/{len(video_files)}] Processing: {os.path.basename(video_file)}")
            
            # Create output filename
            base_name = os.path.splitext(os.path.basename(video_file))[0]
            output_file = os.path.join(output_folder, f"{base_name}_mobile.mp4")
            
            # Convert
            if self.convert_to_mobile(video_file, output_file, quality):
                success_count += 1
            else:
                failed_count += 1
        
        # Summary
        print("\n" + "=" * 60)
        print("📊 CONVERSION SUMMARY:")
        print(f"   ✅ Successful: {success_count}")
        print(f"   ❌ Failed: {failed_count}")
        print(f"   📁 Output folder: {output_folder}")
        
        if success_count > 0:
            print(f"\n📱 Converted videos are ready for mobile playback!")
    
    def extract_frames(self, video_file, output_folder, fps=1):
        """Extract frames from video as images"""
        if not os.path.exists(video_file):
            print(f"❌ File not found: {video_file}")
            return
        
        os.makedirs(output_folder, exist_ok=True)
        
        cmd = [
            self.ffmpeg_path,
            '-i', video_file,
            '-vf', f'fps={fps}',
            os.path.join(output_folder, 'frame_%04d.jpg'),
            '-y'
        ]
        
        try:
            print(f"\n📸 Extracting frames (1 per {fps} second)...")
            subprocess.run(
                cmd,
                capture_output=True,
                creationflags=subprocess.CREATE_NO_WINDOW if os.name == 'nt' else 0
            )
            
            # Count extracted frames
            frame_count = len([f for f in os.listdir(output_folder) if f.endswith('.jpg')])
            print(f"✅ Extracted {frame_count} frames to: {output_folder}")
            
        except Exception as e:
            print(f"❌ Error extracting frames: {e}")

